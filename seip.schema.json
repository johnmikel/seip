{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SEIP Declaration",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "seip_version",
    "declaration_id",
    "created_at",
    "status",
    "producer",
    "change",
    "timeline",
    "consumers",
    "responses",
    "events"
  ],
  "properties": {
    "seip_version": { "type": "string" },
    "declaration_id": { "type": "string" },
    "created_at": { "type": "string", "format": "date-time" },
    "status": {
      "type": "string",
      "enum": ["DRAFT", "PROPOSED", "UNDER_REVIEW", "ACCEPTED", "ENFORCING", "COMPLETED", "WITHDRAWN", "REJECTED"]
    },
    "producer": {
      "type": "object",
      "additionalProperties": true,
      "required": ["team"],
      "properties": {
        "team": { "type": "string" },
        "contact": { "type": "string" }
      }
    },
    "change": {
      "type": "object",
      "additionalProperties": true,
      "required": ["type", "breaking", "summary", "affected_objects"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["add", "remove", "rename", "retype", "deprecate", "restructure"]
        },
        "breaking": { "type": "boolean" },
        "summary": { "type": "string" },
        "details": { "type": "string" },
        "affected_objects": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true,
            "required": ["object", "property"],
            "properties": {
              "object": { "type": "string" },
              "property": { "type": "string" }
            }
          }
        },
        "renames": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true,
            "required": ["object", "from", "to"],
            "properties": {
              "object": { "type": "string" },
              "from": { "type": "string" },
              "to": { "type": "string" }
            }
          }
        },
        "compatibility": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "backward": { "type": "boolean" },
            "forward": { "type": "boolean" },
            "migration_available": { "type": "boolean" }
          }
        }
      }
    },
    "migration": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "strategy": { "type": "string" },
        "steps": { "type": "array", "items": { "type": "string" } },
        "sql": { "type": "array", "items": { "type": "string" } },
        "rollback": { "type": "string" }
      }
    },
    "timeline": {
      "type": "object",
      "additionalProperties": true,
      "required": ["review_deadline", "deprecation_date", "removal_date"],
      "properties": {
        "review_deadline": { "type": "string", "format": "date-time" },
        "migration_start": { "type": "string", "format": "date-time" },
        "deprecation_date": { "type": "string", "format": "date-time" },
        "removal_date": { "type": "string", "format": "date-time" }
      }
    },
    "consumers": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["team", "status"],
        "properties": {
          "team": { "type": "string" },
          "contact": { "type": "string" },
          "dependencies": { "type": "array", "items": { "type": "string" } },
          "status": {
            "type": "string",
            "enum": ["PENDING", "ACKNOWLEDGED", "OBJECTED", "EXTENSION_REQUESTED"]
          }
        }
      }
    },
    "responses": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["team", "status", "responded_at"],
        "properties": {
          "team": { "type": "string" },
          "status": {
            "type": "string",
            "enum": ["ACKNOWLEDGED", "OBJECTED", "EXTENSION_REQUESTED"]
          },
          "message": { "type": "string" },
          "responded_at": { "type": "string", "format": "date-time" },
          "estimated_effort": { "type": "string" },
          "requested_deadline": { "type": "string", "format": "date-time" }
        }
      }
    },
    "events": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["type", "at"],
        "properties": {
          "type": { "type": "string" },
          "at": { "type": "string", "format": "date-time" },
          "actor": { "type": "string" },
          "message": { "type": "string" },
          "from_status": { "type": ["string", "null"] },
          "to_status": { "type": ["string", "null"] },
          "response_status": { "type": "string" }
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": { "change": { "properties": { "breaking": { "const": true } } } }
      },
      "then": {
        "required": ["migration"],
        "properties": { "migration": { "required": ["strategy"] } }
      }
    }
  ]
}
